# Copy this file to `.env.local` for local development.
# Do not place live Stripe secrets or production Firebase project IDs in non-prod environments.

# Public Firebase config
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:yourappidhere

# Public app config
NEXT_PUBLIC_APP_URL=http://localhost:9002
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GA_ID=

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PRICE_ID_MONTHLY=price_replace_monthly
NEXT_PUBLIC_STRIPE_PRICE_ID_YEARLY=price_replace_yearly
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=
NEXT_PUBLIC_STRIPE_PRICE_ID_PREMIUM=

# AI / analytics / onboarding
DEEPSEEK_API_KEY=
GA_MEASUREMENT_PROTOCOL_API_SECRET=
RESEND_API_KEY=
ONBOARDING_EMAILS_ENABLED=false
ONBOARDING_FROM_EMAIL=
ONBOARDING_REPLY_TO=
ONBOARDING_EMAIL_SECRET=
ONBOARDING_RUN_SECRET=
ONBOARDING_BOUNCE_SECRET=

# Optional server/runtime values
GOOGLE_CLOUD_PROJECT=
APP_TRIAL_DAYS=7
STRIPE_TRIAL_DAYS=7
