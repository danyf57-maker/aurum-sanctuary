rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function sensitiveUserFields() {
      return [
        'stripeCustomerId',
        'subscriptionStatus',
        'subscriptionId',
        'subscriptionPriceId',
        'subscriptionCurrentPeriodEnd',
        'subscriptionTrialEndsAt',
        'trialStartedAt',
        'trialConsumedAt',
        'trialConfiguredDays',
        'trialOrigin',
        'billingPhase'
      ];
    }

    function userCreateAllowedFields() {
      return [
        'uid',
        'email',
        'firstName',
        'displayName',
        'photoURL',
        'createdAt',
        'updatedAt',
        'entryCount'
      ];
    }

    // ---------------------------------------------------------
    // Public Content (Blog)
    // ---------------------------------------------------------
    match /publicPosts/{postId} {
      allow read: if true;
      allow write: if false; // Admin only
    }

    // ---------------------------------------------------------
    // Users Collection (Root)
    // Architecture: Admin-Blind
    // ---------------------------------------------------------
    
    match /users/{userId} {
      // READ: Owner only
      // WRITE: Allow owner to CREATE minimal profile doc only
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.keys().hasOnly(userCreateAllowedFields())
        && !request.resource.data.keys().hasAny(sensitiveUserFields());
      // Owner updates allowed except sensitive billing/subscription fields.
      allow update: if isOwner(userId)
        && !request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasAny(sensitiveUserFields());

      // -------------------------------------------------------
      // Settings Subcollection
      // -------------------------------------------------------
      
      // Legal Settings (Terms Acceptance) - WRITABLE by Client
      match /settings/legal {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // General Settings - WRITABLE by Client
      match /settings/preferences {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // -------------------------------------------------------
      // Entries Subcollection (Journal)
      // -------------------------------------------------------
      match /entries/{entryId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);

        // Aurum Conversation (sub-collection of entries)
        match /aurumConversation/{turnId} {
          allow read: if isOwner(userId);
          allow write: if false; // Written by server only
        }
      }

      // -------------------------------------------------------
      // Magazine Issues (Derived cards for journal browsing)
      // -------------------------------------------------------
      match /magazineIssues/{issueId} {
        allow read: if isOwner(userId);
        // Writes are expected from trusted server code (Admin SDK)
        allow write: if false;
      }

      // -------------------------------------------------------
      // Insights Subcollection (Generated by Server)
      // -------------------------------------------------------
      match /insights/{insightId} {
        allow read: if isOwner(userId);
        allow write: if false; // Generated by Server only
      }

      // -------------------------------------------------------
      // Assessments (Parcours d'entree / quiz landing)
      // -------------------------------------------------------
      match /assessments/{assessmentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // -------------------------------------------------------
      // Wellbeing Scores
      // -------------------------------------------------------
      match /wellbeingScores/{scoreId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // -------------------------------------------------------
      // Personality Scores
      // -------------------------------------------------------
      match /personalityScores/{scoreId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // -------------------------------------------------------
      // Collections (User-created groupings)
      // -------------------------------------------------------
      match /collections/{collectionId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // -------------------------------------------------------
      // Derived Memory (Stats)
      // -------------------------------------------------------
      match /derivedMemory/{docId} {
        allow read: if isOwner(userId);
        allow write: if false; // Updated by Server only
      }
    }
  }
}
